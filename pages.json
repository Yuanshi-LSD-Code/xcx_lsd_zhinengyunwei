				}
			}]
		},
		{
			"root": "pages/factoryAllStatus",
			"pages": [{
				"path": "factoryAllStatus",
				"style": {
					"navigationBarTitleText": "所有工厂",
					"enablePullDownRefresh": false
				}
			}, {
				"path": "factoryOneStatus",
				"style": {
					"navigationBarTitleText": "工厂",
					"enablePullDownRefresh": false
				}
			}, {
				"path": "factoryOneDjStatus",
				"style": {
					"navigationBarTitleText": "工厂",
					"enablePullDownRefresh": false
				}
			}]
		},
		{
			"root": "pages/djDetail",
			"pages": [{
				"path": "djDetail",
				"style": {
					"navigationBarTitleText": "电机信息"
				}
			}]
		}

	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "",
		"navigationBarBackgroundColor": "#ffffff",
