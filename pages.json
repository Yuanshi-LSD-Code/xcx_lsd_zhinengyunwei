{
	"easycom": {
		"^u-(.*)": "uview-ui/components/u-$1/u-$1.vue",
		"tui-(.*)": "@/components/thorui/tui-$1/tui-$1.vue",
		"fui-(.*)": "@/components/firstui/fui-$1/fui-$1.vue",
		"uni-(.*)": "@/uni_modules/lime-echart/components/$1-echart/$1-echart.vue"


	},

	"pages": [{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "所有工厂",
				"enablePullDownRefresh": false
			}

		},
		{
			"path": "pages/notice/notice",
			"style": {
				"navigationBarTitleText": "消息",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/user/user",
			"style": {
				"navigationBarTitleText": "我的",
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/ai/ai",
			"style": {
				"navigationBarTitleText": "AI助手",
				"enablePullDownRefresh": false,
				"navigationStyle": "custom"   // 新增此行
			}
		},
		{
			"path": "pages/privacyPolicyProtocol/privacyPolicyProtocol",
			"style": {
				"navigationBarTitleText": "隐私政策及注册协议",
				"enablePullDownRefresh": false
			}

		}



	],

	"subPackages": [{
			"root": "pages/factory",
			"pages": [{
				"path": "factory",
				"style": {
					"navigationBarTitleText": "所有工厂"
				}
			}]
		},
		{
			"root": "pages/noticeDetail",
