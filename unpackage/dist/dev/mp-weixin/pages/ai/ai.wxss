/* 自定义导航栏 */
.custom-navbar.data-v-f5844974 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  z-index: 1000;
  border-bottom: 1rpx solid #f0f0f0;
}
.navbar-content.data-v-f5844974 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  height: 44px;
  box-sizing: border-box;
}
.navbar-left.data-v-f5844974 {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex: 1;
}
.nav-btn.data-v-f5844974 {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  transition: -webkit-transform 0.3s ease;
  transition: transform 0.3s ease;
  transition: transform 0.3s ease, -webkit-transform 0.3s ease;
}
.nav-btn.data-v-f5844974:active {
  -webkit-transform: scale(0.9);
          transform: scale(0.9);
}
.nav-icon.data-v-f5844974 {
  width: 40rpx;
  height: 40rpx;
}
.navbar-title.data-v-f5844974 {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  flex: 2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.navbar-right.data-v-f5844974 {
  flex: 1;
  display: flex;
  justify-content: flex-end;
}
/* 历史记录悬浮层 */
.history-overlay.data-v-f5844974 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  z-index: 999;
}
.history-picker-container.data-v-f5844974 {
  position: fixed;
  top: 0;
  left: 0;
  width: 50%;
  background-color: #ffffff;
  z-index: 1000;
  box-shadow: 2rpx 0 10rpx rgba(0, 0, 0, 0.1);
  transition: -webkit-transform 0.3s ease;
  transition: transform 0.3s ease;
  transition: transform 0.3s ease, -webkit-transform 0.3s ease;
  overflow: hidden;
}
.history-list.data-v-f5844974 {
  height: 100%;
  width: 100%;
  padding: 20rpx;
  box-sizing: border-box;
  margin-top:80px;
}
.history-item.data-v-f5844974 {
  padding: 10rpx 5rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  min-height: 80rpx;
  transition: background-color 0.3s;
}
.history-item.data-v-f5844974:active {
  background-color: #f5f5f5;
}
.history-item-text.data-v-f5844974 {
  font-size: 32rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-word;
  white-space: normal;
  width: 100%;
}
.empty-history.data-v-f5844974 {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200rpx;
}
.empty-text.data-v-f5844974 {
  font-size: 28rpx;
  color: #999;
}
/* 容器使用 flex 布局 */
.container.data-v-f5844974 {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  box-sizing: border-box;
  position: relative;
}
/* 聊天区域 */
.chat-list.data-v-f5844974 {
  flex: 1;
  overflow-y: auto;
  padding: 10px 15px 510rpx; /* 底部留出输入框区域的空间 */
  box-sizing: border-box;
}
/* 初始提示文字 */
.empty-chat-tip.data-v-f5844974 {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
}
.empty-chat-text.data-v-f5844974 {
  color: #000000;
  font-size: 18px;
  text-align: center;
}
/* 消息容器 */
.chat-message.data-v-f5844974 {
  display: flex;
  margin-bottom: 10px;
}
/* 用户消息靠右 */
.user-message.data-v-f5844974 {
  justify-content: flex-end;
}
/* 助手消息靠左 */
.assistant-message.data-v-f5844974 {
  justify-content: flex-start;
}
/* 消息气泡 */
.message-bubble.data-v-f5844974 {
  max-width: 80%;
  padding: 10px 14px;
  border-radius: 12px;
  word-wrap: break-word;
  overflow-wrap: break-word;
  white-space: pre-wrap;
}
/* 用户气泡颜色 */
.user-message .message-bubble.data-v-f5844974 {
  background-color: #DCF8C6;
}
/* 助手气泡颜色 */
.assistant-message .message-bubble.data-v-f5844974 {
  background-color: #E5E5E5;
}
/* 消息文本 */
.message-text.data-v-f5844974 {
  font-size: 15px;
  line-height: 1.5;
  color: #333;
}
/* 底部锚点 */
#bottom.data-v-f5844974 {
  height: 1px;
}
/* 原有样式保留（但不再使用 .text-display-container 等） */
.text-display-container.data-v-f5844974,
.display-text.data-v-f5844974,
.user-input-display-container.data-v-f5844974,
.user-input-display-text.data-v-f5844974 {
  display: none;
}
.textarea-container.data-v-f5844974 {
  position: fixed;
  left: 50rpx;
  right: 50rpx;
  bottom: 240rpx; /* 为按钮留出空间：按钮高度50rpx + 下边距80rpx + 间距10rpx */
  min-height: 200rpx;
  z-index: 100;
}
.textarea.data-v-f5844974 {
  width: 100%;
  min-height: inherit;
  background-color: #f0f0f0; /* 浅灰色填充 */
  border-radius: 25rpx; /* 圆弧倒角，高度的一半 */
  padding: 30rpx;
  font-size: 32rpx; /* 8号字体 */
  color: #000000; /* 黑色 */
  font-family: "SimSun", "宋体", sans-serif; /* 宋体 */
  border: 1rpx solid #cccccc; /* 灰色细框 */
  box-sizing: border-box;
}
.button-container.data-v-f5844974 {
  position: fixed;
  left: 50rpx;
  bottom: 180rpx;
  width: 550rpx;
  height: 50rpx;
  background-color: #f0f0f0;
  border-radius: 25rpx;
  border: 1rpx solid #cccccc;
  display: block;
  z-index: 100;
  overflow: visible;
  pointer-events: auto;
  padding: 0;
  margin: 0;
}
/* 确保 picker 内部的 text 元素占满整个容器 */
.button-container .button-text.data-v-f5844974 {
  width: 100%;
  height: 100%;
  display: block;
  font-size: 32rpx;
  color: #000000;
  font-family: "SimSun", "宋体", sans-serif;
  text-align: center;
  line-height: 50rpx; /* 与 .button-container 的 height 相同 */
  padding: 0 20rpx;
  box-sizing: border-box;
}
.button-container.data-v-f5844974:active {
  opacity: 0.8;
}
.button-text.data-v-f5844974 {
  font-size: 32rpx; /* 8号字体 */
  color: #000000; /* 黑色 */
  font-family: "SimSun", "宋体", sans-serif; /* 宋体 */
}
.circle-button.data-v-f5844974 {
  position: fixed;
  right: 50rpx; /* 右侧距离屏幕右边50rpx */
  bottom: 180rpx; /* 下边距离屏幕下边80rpx */
  width: 50rpx; /* 直径 */
  height: 50rpx; /* 直径 */
  background-color: #87CEEB; /* 天蓝色 */
  border-radius: 50%; /* 圆形 */
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}
.circle-button.data-v-f5844974:active {
  opacity: 0.8;
  -webkit-transform: scale(0.95);
          transform: scale(0.95);
}
.circle-button.loading.data-v-f5844974 {
  opacity: 0.7;
  background-color: #5bc0de;
}
.circle-button.disabled.data-v-f5844974 {
  background-color: #cccccc;
  opacity: 0.5;
  pointer-events: none;
}
.circle-button-text.data-v-f5844974 {
  font-size: 40rpx;
  color: white;
  font-weight: bold;
  line-height: 1;
}
/* 耗时文字样式 */
.duration-text.data-v-f5844974 {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}
/* 底部提示文字样式 */
.footer-notice.data-v-f5844974 {
  position: fixed;
  bottom: 120rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 26rpx;
  color: #999999; /* 灰色 */
  z-index: 1;
}

