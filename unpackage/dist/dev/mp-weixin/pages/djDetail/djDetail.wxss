
.sticky-container {
	position: fixed;
	/* position: sticky; */
	top: 0;
	z-index: 99;
	width: 100%;
}
.tab-container {
    display: flex;
    height: 40px;
    border-bottom: 1px solid #ddd;
}
.tab {
    flex: 1;
    text-align: center;
    padding: 10px;
    position: relative;
    cursor: pointer;
}
.tab.active {
    font-weight: bold;
    color: blue;
}
.underline {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: blue;
}



